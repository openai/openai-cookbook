#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
spec="$repo_root/.agents/agent-specs/reviewer.yaml"

name="$(sed -n 's/^name: //p' "$spec")"
description="$(sed -n 's/^description: //p' "$spec")"
prompt_path="$(sed -n 's/^prompt: //p' "$spec")"
prompt="$(cat "$repo_root/$prompt_path")"

cat > "$repo_root/.claude/agents/$name.md" <<EOF
<!-- Generated by tools/agent-config/generate. Do not edit directly. -->
---
name: $name
description: $description
tools: Read, Grep, Glob
---

$prompt
EOF

cat > "$repo_root/.codex/agents/$name.toml" <<EOF
# Generated by tools/agent-config/generate. Do not edit directly.
name = "$name"
description = "$description"
sandbox_mode = "read-only"
developer_instructions = """
$prompt
"""
EOF
