#!/usr/bin/env python3
"""Render provider-native agents from checked-in TOML specifications."""

from __future__ import annotations

import argparse
import difflib
import json
import os
import re
import sys
import tempfile
import tomllib
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parents[2]
SPEC_DIR = ROOT / ".agents/agent-specs"
MARKER = "Generated by tools/agent-config/generate. Do not edit directly."
NAME_PATTERN = re.compile(r"^[a-z][a-z0-9-]*$")


class ConfigError(ValueError):
    """Raised when a checked-in agent specification is invalid."""


def repo_path(value: str, *, context: str) -> Path:
    candidate = Path(value)
    if candidate.is_absolute():
        raise ConfigError(f"{context} must be relative to the repository root")
    path = (ROOT / candidate).resolve()
    try:
        path.relative_to(ROOT)
    except ValueError as error:
        raise ConfigError(f"{context} escapes the repository root: {value}") from error
    return path


def require_only(data: dict[str, Any], allowed: set[str], *, context: str) -> None:
    unknown = sorted(set(data) - allowed)
    if unknown:
        raise ConfigError(f"{context} has unsupported fields: {', '.join(unknown)}")


def require_table(data: dict[str, Any], key: str, *, context: str) -> dict[str, Any]:
    value = data.get(key)
    if not isinstance(value, dict):
        raise ConfigError(f"{context}.{key} must be a table")
    return value


def require_string(data: dict[str, Any], key: str, *, context: str) -> str:
    value = data.get(key)
    if not isinstance(value, str) or not value.strip():
        raise ConfigError(f"{context}.{key} must be a non-empty string")
    return value.strip()


def require_string_list(data: dict[str, Any], key: str, *, context: str) -> list[str]:
    value = data.get(key)
    if (
        not isinstance(value, list)
        or not value
        or not all(isinstance(item, str) and item.strip() for item in value)
    ):
        raise ConfigError(f"{context}.{key} must be a non-empty array of strings")
    return [item.strip() for item in value]


def render_claude(name: str, description: str, prompt: str, config: dict[str, Any]) -> str:
    require_only(config, {"output", "tools", "model"}, context="claude")
    tools = ", ".join(require_string_list(config, "tools", context="claude"))
    return "\n".join(
        [
            "---",
            f"# {MARKER}",
            f"name: {json.dumps(name, ensure_ascii=False)}",
            f"description: {json.dumps(description, ensure_ascii=False)}",
            f"tools: {json.dumps(tools, ensure_ascii=False)}",
            f"model: {json.dumps(require_string(config, 'model', context='claude'))}",
            "---",
            "",
            prompt.rstrip(),
            "",
        ]
    )


def render_codex(name: str, description: str, prompt: str, config: dict[str, Any]) -> str:
    require_only(
        config,
        {
            "output",
            "nickname_candidates",
            "model_reasoning_effort",
            "sandbox_mode",
        },
        context="codex",
    )
    nicknames = require_string_list(config, "nickname_candidates", context="codex")
    if len(set(nicknames)) != len(nicknames):
        raise ConfigError("codex.nickname_candidates must contain unique values")
    return "\n".join(
        [
            f"# {MARKER}",
            f"name = {json.dumps(name, ensure_ascii=False)}",
            f"description = {json.dumps(description, ensure_ascii=False)}",
            f"nickname_candidates = {json.dumps(nicknames, ensure_ascii=False)}",
            "model_reasoning_effort = "
            f"{json.dumps(require_string(config, 'model_reasoning_effort', context='codex'))}",
            "sandbox_mode = "
            f"{json.dumps(require_string(config, 'sandbox_mode', context='codex'))}",
            f"developer_instructions = {json.dumps(prompt.rstrip(), ensure_ascii=False)}",
            "",
        ]
    )


def load_outputs() -> dict[Path, str]:
    specs = sorted(SPEC_DIR.glob("*.toml"))
    if not specs:
        raise ConfigError(f"no TOML specifications found under {SPEC_DIR.relative_to(ROOT)}")

    outputs: dict[Path, str] = {}
    for spec_path in specs:
        context = str(spec_path.relative_to(ROOT))
        with spec_path.open("rb") as handle:
            spec = tomllib.load(handle)
        require_only(
            spec,
            {"name", "description", "prompt", "claude", "codex"},
            context=context,
        )

        name = require_string(spec, "name", context=context)
        if not NAME_PATTERN.fullmatch(name):
            raise ConfigError(f"{context}.name must match {NAME_PATTERN.pattern}")
        description = require_string(spec, "description", context=context)
        prompt_path = repo_path(
            require_string(spec, "prompt", context=context), context=f"{context}.prompt"
        )
        if not prompt_path.is_file():
            raise ConfigError(f"prompt file does not exist: {prompt_path.relative_to(ROOT)}")
        prompt = prompt_path.read_text(encoding="utf-8")

        claude = require_table(spec, "claude", context=context)
        codex = require_table(spec, "codex", context=context)
        rendered = [
            (
                repo_path(
                    require_string(claude, "output", context="claude"),
                    context="claude.output",
                ),
                render_claude(name, description, prompt, claude),
            ),
            (
                repo_path(
                    require_string(codex, "output", context="codex"),
                    context="codex.output",
                ),
                render_codex(name, description, prompt, codex),
            ),
        ]

        for path, content in rendered:
            if path in outputs:
                raise ConfigError(f"multiple specs generate {path.relative_to(ROOT)}")
            outputs[path] = content
    return outputs


def update(path: Path, content: str, *, check: bool) -> bool:
    current = path.read_text(encoding="utf-8") if path.exists() else ""
    if current == content:
        return True
    if check:
        sys.stdout.writelines(
            difflib.unified_diff(
                current.splitlines(keepends=True),
                content.splitlines(keepends=True),
                fromfile=str(path.relative_to(ROOT)),
                tofile=f"{path.relative_to(ROOT)} (expected)",
            )
        )
        return False

    path.parent.mkdir(parents=True, exist_ok=True)
    descriptor, temporary_name = tempfile.mkstemp(
        dir=path.parent, prefix=f".{path.name}.", text=True
    )
    try:
        with os.fdopen(descriptor, "w", encoding="utf-8", newline="\n") as handle:
            handle.write(content)
            handle.flush()
            os.fsync(handle.fileno())
        os.chmod(temporary_name, 0o644)
        os.replace(temporary_name, path)
    finally:
        if os.path.exists(temporary_name):
            os.unlink(temporary_name)
    print(f"updated {path.relative_to(ROOT)}")
    return True


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--check", action="store_true", help="report drift without changing files"
    )
    args = parser.parse_args()

    try:
        outputs = load_outputs()
        results = [
            update(path, content, check=args.check)
            for path, content in sorted(outputs.items(), key=lambda item: str(item[0]))
        ]
        clean = all(results)
    except (ConfigError, OSError, tomllib.TOMLDecodeError) as error:
        print(f"agent-config: {error}", file=sys.stderr)
        return 2

    if args.check and not clean:
        print("agent-config: generated files are out of date", file=sys.stderr)
        print("run tools/agent-config/generate", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
